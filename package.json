{
  "name": "dsvisual",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "test": "playwright test",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:all": "npm run test:unit && npm test",
    "build:slides": "node build_slides.js",
    "slides:pdf": "marp --pdf --allow-local-files --input-dir slides/zh -o slides/pdf/zh && marp --pdf --allow-local-files --input-dir slides/en -o slides/pdf/en",
    "format:code": "node format_code.js",
    "inject-env": "node scripts/inject-env.mjs",
    "pages:prepare": "npm run inject-env && npm run build:slides",
    "pages:artifact": "npm run pages:prepare && node scripts/prepare-pages-artifact.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skhuang/dsvisual.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/skhuang/dsvisual/issues"
  },
  "homepage": "https://github.com/skhuang/dsvisual#readme",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.4.0",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@playwright/test": "^1.61.1",
    "clang-format": "^1.8.0",
    "firebase": "^11.7.1",
    "katex": "^0.16.47",
    "prismjs": "^1.30.0"
  }
}
